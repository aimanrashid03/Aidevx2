# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────
# PRIMARY SETUP — Supabase Cloud (recommended)
# ─────────────────────────────────────────────────────────────────────────────

# ----- Supabase (cloud) -----
# Get these from: https://supabase.com/dashboard → project → Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key-here...

# ----- OnlyOffice Document Server (cloud — Oracle Cloud ARM VM) -----
# Production OO server: http://149.118.143.205:8080 (JWT_ENABLED=false)
# If using nip.io TLS termination: https://149.118.143.205.nip.io
VITE_ONLYOFFICE_SERVER_URL=http://149.118.143.205:8080

# Secret token used to authenticate OnlyOffice save callbacks.
# Must match ONLYOFFICE_CALLBACK_SECRET set via `supabase secrets set`.
VITE_ONLYOFFICE_CALLBACK_SECRET=aidevx-oo-callback-secret-change-in-prod

# OO callback base URL — the address OnlyOffice uses to reach your edge functions.
# Cloud: use your Supabase project URL (OO server calls Supabase directly over the internet).
VITE_ONLYOFFICE_CALLBACK_BASE_URL=https://<project-ref>.supabase.co

# OnlyOffice JWT signing secret — only set if JWT_ENABLED=true on the OO server.
# The production OO server has JWT_ENABLED=false — leave this unset.
# VITE_ONLYOFFICE_JWT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Local Supabase setup (contributors / isolated dev)
# Run `supabase start` to spin up the local instance and get these values.
# ─────────────────────────────────────────────────────────────────────────────

# ----- Supabase (local) -----
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMbJsyH-qQwg

# ----- OnlyOffice Document Server (local — docker compose up -d) -----
# VITE_ONLYOFFICE_SERVER_URL=http://localhost:8080

# OO callback base URL for local setup — OnlyOffice (inside Docker) must reach
# Supabase Kong via the internal Docker network (not localhost).
# Network name must match your local Docker network (`docker network ls`).
# VITE_ONLYOFFICE_CALLBACK_BASE_URL=http://supabase_kong_Aidevx2:8000

# OO JWT secret — only needed if you run a local OO server with JWT_ENABLED=true.
# VITE_ONLYOFFICE_JWT_SECRET=
