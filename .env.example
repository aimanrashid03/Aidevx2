# Copy this file to .env and fill in the values.
# The Supabase values below are the standard defaults for a local `supabase start` instance.

# ----- Supabase (local dev) -----
# Run `supabase start` to spin up the local instance and get these values.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMbJsyH-qQwg

# ----- OnlyOffice Document Server -----
# Matches the port exposed by docker compose (docker-compose.yml).
VITE_ONLYOFFICE_SERVER_URL=http://localhost:8080

# Secret token used to authenticate OnlyOffice save callbacks.
# Must match ONLYOFFICE_CALLBACK_SECRET in supabase/.env.local.
VITE_ONLYOFFICE_CALLBACK_SECRET=aidevx-oo-callback-secret-change-in-prod

# Internal Docker network address so OnlyOffice (inside Docker) can reach Supabase Kong.
# The network name must match your local Docker network (check `docker network ls`).
# Default: supabase_kong_Aidevx2:8000
VITE_ONLYOFFICE_CALLBACK_BASE_URL=http://supabase_kong_Aidevx2:8000
