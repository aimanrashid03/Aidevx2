# Copy this file to supabase/.env.local and fill in the values.
# This file is used by `npm run functions` (supabase functions serve).
# NEVER commit supabase/.env.local — it contains secrets.

# ── LLM (Anthropic Claude) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key-here...

# Optional overrides (defaults are already set for Claude Haiku + Voyage):
# LLM_PROVIDER=anthropic               # or 'openai' to fall back to OpenAI
# LLM_MODEL=claude-haiku-4-5-20251001
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_TEMPERATURE=0.4

# ── Embeddings (Voyage AI) ────────────────────────────────────────────────────
VOYAGE_API_KEY=pa-...your-voyage-key-here...

# Optional overrides:
# EMBEDDING_MODEL=voyage-3-lite
# EMBEDDING_BASE_URL=https://api.voyageai.com/v1
# EMBEDDING_DIMENSIONS=512

# ── RAG tuning ────────────────────────────────────────────────────────────────
# RAG_MATCH_THRESHOLD=0.30
# RAG_MATCH_COUNT=18

# ── OnlyOffice ────────────────────────────────────────────────────────────────
# Must match VITE_ONLYOFFICE_CALLBACK_SECRET in your root .env file.
ONLYOFFICE_CALLBACK_SECRET=aidevx-oo-callback-secret-change-in-prod

# ── Extended timeout for auto_generate_document (17 sequential LLM calls) ─────
SUPABASE_FUNCTIONS_WALL_CLOCK_TIMEOUT=600
