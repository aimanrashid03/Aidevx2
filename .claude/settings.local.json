{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(docker ps:*)",
      "Read(//home/user/**)",
      "Bash(python3 -m json.tool)",
      "Bash(curl:*)",
      "Bash(docker exec:*)",
      "Bash(npm install:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(npm run:*)",
      "Bash(npx tsc:*)",
      "Bash(xargs grep:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/block-git-push.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/protect-config.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/notify-file-changed.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/precompact-state.sh\""
          }
        ]
      }
    ]
  }
}
